#!/usr/bin/env bash
# postinstall — runs after pkgbuild places files at their install locations.
#
# What this script does:
#   1. Clears the macOS quarantine extended attribute on the daemon binary so
#      Gatekeeper does not block the first run with an "unidentified developer"
#      error.  (ADR-020, Wave 0 confirmed decision 2026-05-09)
#   2. CRITICAL (ADR-022 Constraint 1): Detects and bootout/unloads the OLD
#      com.mtga-companion.daemon LaunchAgent if it is registered, BEFORE
#      registering the new one.  Prevents two daemon processes from running
#      simultaneously after an in-place upgrade.
#   3. Writes a default LaunchAgent plist to ~/Library/LaunchAgents/ using the
#      channel-derived label (per-user, not system-wide — no sudo).
#   4. Loads the new LaunchAgent with launchctl bootstrap so the daemon starts
#      immediately without requiring a logout/login cycle.
#
# Identity constants (BINARY_NAME, PLIST_LABEL, KEYCHAIN_SERVICE, CONFIG_DIR,
# APP_BUNDLE_PATH) are DERIVED from CHANNEL using the same suffix table as
# common.sh (ADR-036 I-4 / ADR-049 §2).  No per-channel literal appears
# outside the suffix case statement below.
#
# The Clerk env vars (CLERK_FRONTEND_API, CLERK_PUBLISHABLE_KEY) and
# cloud_api_url are baked in at build time via the CI workflow's env block
# and embedded into the plist EnvironmentVariables and daemon.json respectively.

set -euo pipefail

INSTALL_DIR="${INSTALL_DIR:-/usr/local/bin}"

# Share directory — must match SHARE_DIR in build-pkg.sh and helperShareDir
# in collection.go.  Use env override in tests; production path is the default.
SHARE_DIR="${SHARE_DIR:-/usr/local/share/vaultmtg}"

# Resolve the real (non-root) user so all files under $HOME are created with
# correct ownership. postinstall runs as root; $SUDO_USER names the invoking
# user. Fall back to the stat owner of $HOME for non-interactive installs.
REAL_USER="${SUDO_USER:-$(stat -f '%Su' "${HOME}")}"
REAL_UID=$(id -u "${REAL_USER}")
REAL_HOME=$(eval echo "~${REAL_USER}")

# Values are substituted at build time by .github/workflows/daemon-release.yml
# using `sed` BEFORE pkgbuild is invoked. pkgbuild does NOT propagate env vars
# from CI to the installed postinstall script — the postinstall runs in macOS
# Installer's own (empty) environment on the user's machine, so `${VAR:-default}`
# expansions here would always resolve to the default. Substituting placeholders
# at build time is the only reliable way to inject build-specific values.
CLOUD_API_URL="__VAULTMTG_CLOUD_API_URL__"
CLERK_FRONTEND_API="__CLERK_FRONTEND_API__"
CLERK_PUBLISHABLE_KEY="__CLERK_PUBLISHABLE_KEY__"
CLERK_OAUTH_CLIENT_ID="__CLERK_OAUTH_CLIENT_ID__"
# CHANNEL is the build-time channel discriminator (ADR-049 §2).
# Values: "stable" (bare daemon/v* tag) or "staging" (pre-release suffix).
CHANNEL="__VAULTMTG_CHANNEL__"

# Fail loudly if any placeholder was not substituted at build time.
for var in CLOUD_API_URL CLERK_FRONTEND_API CLERK_PUBLISHABLE_KEY CLERK_OAUTH_CLIENT_ID CHANNEL; do
  eval "value=\${$var}"
  case "$value" in
    __*__)
      echo "[postinstall] ERROR: build-time substitution did not run for ${var} (still '${value}')" >&2
      exit 1
      ;;
  esac
done

# ---------------------------------------------------------------------------
# Derive channel-keyed identity constants (mirrors common.sh suffix table).
# ADR-036 I-4 / ADR-049 §2: single source of truth is common.sh; this block
# reproduces the same case statement so postinstall is self-contained when
# embedded in the .pkg (common.sh is not packaged into the scripts dir).
# Adding a future channel: add one case arm here AND in common.sh.
# ---------------------------------------------------------------------------
case "${CHANNEL}" in
  stable)
    SUFFIX=""
    LABEL_SUFFIX=""
    APP_SUFFIX=""
    ;;
  staging)
    SUFFIX="-staging"
    LABEL_SUFFIX=".staging"
    APP_SUFFIX=" Staging"
    ;;
  *)
    echo "[postinstall] ERROR: unknown CHANNEL '${CHANNEL}' — must be 'stable' or 'staging'" >&2
    exit 1
    ;;
esac

BINARY_NAME="vaultmtg-daemon${SUFFIX}"
BINARY_PATH="${INSTALL_DIR}/${BINARY_NAME}"

PLIST_LABEL="com.vaultmtg.daemon${LABEL_SUFFIX}"
# Legacy label — only applicable for stable channel (staging never had one).
# Left unset for staging so guard blocks below skip cleanly.
PLIST_LABEL_LEGACY=""
if [[ "${CHANNEL}" == "stable" ]]; then
  PLIST_LABEL_LEGACY="com.mtga-companion.daemon"
fi

# OS keychain service (matches keychain.go ServiceNameNew / common.sh KEYCHAIN_SERVICE).
# ADR-022 Phase 3 (v0.3.9): the LIVE keychain service is com.hollowmark.daemon —
# NOT com.vaultmtg.daemon.  keychain.go ServiceNameNew = "com.hollowmark.daemon";
# ServiceNameLegacy = "com.vaultmtg.daemon" is a READ-ONLY upgrade fallback.
# postinstall must target the hollowmark namespace for any keychain write/delete.
# This mirrors common.sh:73 ("com.hollowmark.daemon${LABEL_SUFFIX}") exactly.
KEYCHAIN_SERVICE="com.hollowmark.daemon${LABEL_SUFFIX}"

# Per-user paths (all relative to the real user's home).
PLIST_DIR="${REAL_HOME}/Library/LaunchAgents"
PLIST_PATH="${PLIST_DIR}/${PLIST_LABEL}.plist"
PLIST_PATH_LEGACY="${PLIST_DIR}/${PLIST_LABEL_LEGACY}.plist"

CONFIG_DIR="${REAL_HOME}/.vaultmtg${SUFFIX}"
CONFIG_FILE="${CONFIG_DIR}/daemon.json"

LOG_FILE="${REAL_HOME}/Library/Logs/vaultmtg-daemon${SUFFIX}.log"

# Local-API port for the post-install liveness check.
# stable=9001, staging=9011 (matches common.sh LOCAL_API_PORT and Go install.stagingPortOffset).
if [[ "${CHANNEL}" == "staging" ]]; then
  LOCAL_API_PORT=9011
else
  LOCAL_API_PORT=9001
fi
HEALTH_URL="http://127.0.0.1:${LOCAL_API_PORT}/health"

# App bundle path (honor env override for tests).
APP_BUNDLE_PATH="${APP_BUNDLE_PATH:-/Applications/VaultMTG${APP_SUFFIX}.app}"

# ---------------------------------------------------------------------------
# 1. Clear quarantine attribute (ADR-020 §macOS Quarantine Clearing).
#
#    -dr = dereference symlinks and recurse (safe on a single binary).
#    This must run before the LaunchAgent loads the binary, otherwise macOS
#    will block execution on first run with a Gatekeeper "unidentified developer"
#    dialog — even for signed binaries that have not yet been notarized.
# ---------------------------------------------------------------------------
echo "[postinstall] clearing quarantine attribute on ${BINARY_PATH}"
xattr -dr com.apple.quarantine "${BINARY_PATH}" || true

# ---------------------------------------------------------------------------
# 2. Write / update daemon.json with cloud_api_url.
#
#    Fresh install (file absent):
#      Write a minimal config with cloud_api_url + sync_enabled.
#
#    Reinstall / upgrade (file exists):
#      Read the existing cloud_api_url.  If it differs from the baked-in
#      CLOUD_API_URL (cross-env reinstall — e.g. staging -> prod), clear
#      the stale keychain credential (api-key) and update cloud_api_url
#      in-place, preserving all other fields (api_key, account_id, etc.).
#
#    Use install(1) for new files so ownership is set to the real user,
#    not root.  In-place patching with python3 is done as the real user via
#    su/sudo to avoid root-owned config that the daemon (running as the user)
#    cannot write later.
# ---------------------------------------------------------------------------
KEYCHAIN_ACCOUNT="api-key"

install -d -m 755 -o "${REAL_USER}" "${CONFIG_DIR}"
if [[ ! -f "${CONFIG_FILE}" ]]; then
  echo "[postinstall] writing ${CONFIG_FILE}"
  install -m 600 -o "${REAL_USER}" /dev/null "${CONFIG_FILE}"
  cat > "${CONFIG_FILE}" <<JSON
{
  "cloud_api_url": "${CLOUD_API_URL}",
  "sync_enabled": true
}
JSON
else
  # Config file exists — check whether cloud_api_url has changed (env-mismatch).
  EXISTING_URL=$(python3 -c "
import json, sys
try:
    with open('${CONFIG_FILE}') as f:
        d = json.load(f)
    print(d.get('cloud_api_url', ''))
except Exception:
    print('')
" 2>/dev/null) || EXISTING_URL=""

  if [[ -n "${EXISTING_URL}" && "${EXISTING_URL}" != "${CLOUD_API_URL}" ]]; then
    echo "[postinstall] cloud_api_url mismatch — cross-env reinstall detected"
    echo "[postinstall]   old: ${EXISTING_URL}"
    echo "[postinstall]   new: ${CLOUD_API_URL}"

    # Clear the stale keychain credential so the daemon doesn't try to auth
    # against the wrong environment with an old api_key (#194).
    echo "[postinstall] clearing stale keychain entry (${KEYCHAIN_SERVICE}/${KEYCHAIN_ACCOUNT})"
    security delete-generic-password \
      -s "${KEYCHAIN_SERVICE}" \
      -a "${KEYCHAIN_ACCOUNT}" 2>/dev/null || true
    echo "[postinstall] keychain entry cleared (or was already absent)"

    # Update cloud_api_url in-place, preserving all other fields.
    python3 - "${CONFIG_FILE}" "${CLOUD_API_URL}" <<'PYEOF'
import json, sys
path, new_url = sys.argv[1], sys.argv[2]
with open(path) as f:
    data = json.load(f)
data['cloud_api_url'] = new_url
with open(path, 'w') as f:
    json.dump(data, f, indent=2)
    f.write('\n')
PYEOF
    echo "[postinstall] cloud_api_url updated in ${CONFIG_FILE}"
  else
    echo "[postinstall] cloud_api_url unchanged — preserving existing config"
  fi
fi

# ---------------------------------------------------------------------------
# 2b. Belt-and-suspenders stale auth clear (#1330 / 2026-06-12 incident).
#
#     On EVERY install/update, unconditionally clear the keychain credentials
#     and the auth fields in daemon.json so the daemon's startup
#     ProbeTokenLiveness probe (#3238 Fix A) runs against a clean slate.
#     The probe itself decides whether PKCE re-auth is needed — the installer
#     cannot probe the BFF from postinstall context.
#
#     Two service names are cleared to cover all field installs:
#       com.hollowmark.daemon — ServiceNameNew  (ADR-022 Phase 3, current)
#       com.vaultmtg.daemon   — ServiceNameLegacy (pre-Phase-3 upgrades)
#
#     Preserved by this block:
#       - archives/ directory and its contents (user's local match archive)
#       - account_id, daemon_id  (identity fields; re-auth reuses them)
#       - sync_enabled, log_path, and all other non-auth config fields
#       - The config file itself (only field values are patched)
#
#     All steps use || true — a fresh install (no keychain entry, no config
#     auth fields) is a no-op and must not fail.
#
#     KEYCHAIN_SERVICE_LEGACY is the read-only fallback service name from
#     keychain.go ServiceNameLegacy.  It does not follow the channel suffix
#     because the legacy name was never channel-suffixed in the field.
# ---------------------------------------------------------------------------
KEYCHAIN_SERVICE_LEGACY="com.vaultmtg.daemon"

if [[ -f "${CONFIG_FILE}" ]]; then
  echo "[postinstall] clearing stale auth state (#1330 — belt-and-suspenders heal)"

  # Clear both keychain service names.  Errors (entry absent) are swallowed with
  # || true so this is idempotent on fresh installs and post-uninstall states.
  security delete-generic-password \
    -s "${KEYCHAIN_SERVICE}" \
    -a "${KEYCHAIN_ACCOUNT}" 2>/dev/null || true
  security delete-generic-password \
    -s "${KEYCHAIN_SERVICE_LEGACY}" \
    -a "${KEYCHAIN_ACCOUNT}" 2>/dev/null || true

  # Zero out auth fields in daemon.json while preserving every other field.
  # python3 is guaranteed present on macOS 11+.
  python3 - "${CONFIG_FILE}" <<'PYEOF' || true
import json, sys
path = sys.argv[1]
try:
    with open(path) as f:
        data = json.load(f)
    # Remove auth fields; silently no-op if they were already absent.
    data.pop('keychain', None)
    data.pop('api_key', None)
    data.pop('daemon_jwt', None)
    with open(path, 'w') as f:
        json.dump(data, f, indent=2)
        f.write('\n')
except Exception as e:
    print(f"[postinstall] WARNING: could not patch daemon.json for stale auth clear: {e}", file=sys.stderr)
PYEOF

  echo "[postinstall] stale auth cleared (keychain entries removed; keychain/api_key/daemon_jwt zeroed)"
else
  echo "[postinstall] no existing daemon.json — fresh install, no stale auth to clear"
fi

# ---------------------------------------------------------------------------
# 3. Ensure LaunchAgents directory exists (owned by the real user).
# ---------------------------------------------------------------------------
install -d -m 755 -o "${REAL_USER}" "${PLIST_DIR}"

# ---------------------------------------------------------------------------
# 4. CRITICAL (ADR-022 Constraint 1): Stop and unregister the OLD daemon label
#    BEFORE writing and bootstrapping the new plist.
#
#    Only applicable for the stable channel — the staging channel never had a
#    legacy identity (com.mtga-companion.daemon).  PLIST_LABEL_LEGACY is empty
#    for staging; this block is skipped.
#
#    If the old label is still registered with launchd, both daemons would run
#    simultaneously after this postinstall completes — causing duplicate log
#    ingestion and BFF event duplication.
#
#    Steps:
#      a. Try label-based bootout (modern, macOS 10.11+) as the real user.
#      b. Fallback: file-based bootout using the legacy plist path.
#      c. Remove the legacy plist so it is not re-loaded at next login.
#    All steps use `|| true` — a fresh install has no legacy label registered.
# ---------------------------------------------------------------------------
if [[ -n "${PLIST_LABEL_LEGACY}" ]]; then
  echo "[postinstall] checking for legacy launchd label ${PLIST_LABEL_LEGACY}"
  if launchctl asuser "${REAL_UID}" launchctl list "${PLIST_LABEL_LEGACY}" >/dev/null 2>&1; then
    echo "[postinstall] found legacy daemon — booting out ${PLIST_LABEL_LEGACY}"
    launchctl asuser "${REAL_UID}" launchctl bootout "gui/${REAL_UID}/${PLIST_LABEL_LEGACY}" 2>/dev/null || \
      launchctl asuser "${REAL_UID}" launchctl bootout "gui/${REAL_UID}" "${PLIST_PATH_LEGACY}" 2>/dev/null || true
    echo "[postinstall] legacy daemon stopped"
  else
    echo "[postinstall] no legacy daemon found — skipping (fresh install)"
  fi

  # Remove legacy plist (idempotent — ignore missing-file errors).
  if [[ -f "${PLIST_PATH_LEGACY}" ]]; then
    echo "[postinstall] removing legacy plist: ${PLIST_PATH_LEGACY}"
    rm -f "${PLIST_PATH_LEGACY}"
  fi
else
  echo "[postinstall] ${CHANNEL} channel — no legacy label to clean up"
fi

# ---------------------------------------------------------------------------
# 5. Write the new LaunchAgent plist (channel-derived label).
#    - RunAtLoad=true   start at login.
#    - KeepAlive=true   restart if the daemon exits unexpectedly.
#    - EnvironmentVariables injects the Clerk values the PKCE flow requires.
#    - -config flag points at CONFIG_FILE (channel-derived path).
#
#    Use install(1) to pre-create the file owned by the real user before
#    writing content. LaunchAgent plists must be owned by the user, not root;
#    a root-owned plist causes launchd to refuse to load it.
# ---------------------------------------------------------------------------
echo "[postinstall] writing LaunchAgent plist to ${PLIST_PATH}"
install -m 644 -o "${REAL_USER}" /dev/null "${PLIST_PATH}"
cat > "${PLIST_PATH}" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${PLIST_LABEL}</string>

    <key>ProgramArguments</key>
    <array>
        <string>${BINARY_PATH}</string>
        <string>-config</string>
        <string>${CONFIG_FILE}</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>CLERK_FRONTEND_API</key>
        <string>${CLERK_FRONTEND_API}</string>
        <key>CLERK_PUBLISHABLE_KEY</key>
        <string>${CLERK_PUBLISHABLE_KEY}</string>
        <key>CLERK_OAUTH_CLIENT_ID</key>
        <string>${CLERK_OAUTH_CLIENT_ID}</string>
        <key>VAULTMTG_DAEMON_CLOUD_API_URL</key>
        <string>${CLOUD_API_URL}</string>
        <key>VAULTMTG_DAEMON_CHANNEL</key>
        <string>${CHANNEL}</string>
    </dict>

    <!-- Start automatically when the user logs in. -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Restart the daemon if it exits for any reason. -->
    <key>KeepAlive</key>
    <true/>

    <!-- Minimum seconds between restarts to prevent launchd restart storms. -->
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>${LOG_FILE}</string>
    <key>StandardErrorPath</key>
    <string>${LOG_FILE}</string>
</dict>
</plist>
PLIST

# ---------------------------------------------------------------------------
# 6. Load the new LaunchAgent into the correct user gui domain.
#
#    pkgbuild postinstall scripts run as root. LaunchAgents must be loaded
#    into the user's gui domain (not the system domain). Use launchctl
#    bootstrap/bootout with the gui/<uid> target, run as the actual user
#    via launchctl asuser so the agent is registered correctly.
# ---------------------------------------------------------------------------
echo "[postinstall] loading LaunchAgent into gui/${REAL_UID} (user: ${REAL_USER})"

# Re-enable the label before bootstrapping. If a previous uninstall called
# "launchctl bootout", launchd marks the label as disabled and a subsequent
# "launchctl bootstrap" fails with error 5 (I/O error). Enabling first
# clears that disabled flag regardless of whether it was set.
launchctl enable "gui/${REAL_UID}/${PLIST_LABEL}"

# Stop any still-running daemon process (covers the same-label reinstall case).
launchctl asuser "${REAL_UID}" launchctl bootout "gui/${REAL_UID}/${PLIST_LABEL}" 2>/dev/null || \
    launchctl asuser "${REAL_UID}" launchctl bootout "gui/${REAL_UID}" "${PLIST_PATH}" 2>/dev/null || true

# Kill any stale processes that slipped past launchctl (e.g. orphaned after a
# crash or a prior install that used a different label).
pkill -x "${BINARY_NAME}" 2>/dev/null || true

# Brief wait so the process has time to exit cleanly before bootstrap starts.
sleep 1

# Wrap bootstrap in a conditional so a transient launchd failure (e.g. when
# the GUI session has not yet started in a script-driven install) does NOT
# cause the entire pkg install to roll back. RunAtLoad=true guarantees the
# daemon will start at the user's next login even if bootstrap is skipped.
if launchctl asuser "${REAL_UID}" launchctl bootstrap "gui/${REAL_UID}" "${PLIST_PATH}"; then
  echo "[postinstall] daemon bootstrapped and running"
else
  echo "[postinstall] WARNING: launchctl bootstrap returned non-zero (GUI session may not be active)."
  echo "[postinstall] The daemon is registered with RunAtLoad=true and will start automatically at next login."
fi

# ---------------------------------------------------------------------------
# 6b. launchd registration liveness check (ADR-083 SH-2 / tickets#1355).
#
#     Verify that launchd has actually registered the service and spawned a
#     process after the bootstrap call above.  The check uses:
#       launchctl print gui/<uid>/<label>
#     and looks for a "pid" field in the output — a non-zero PID means launchd
#     has started the binary.  This is distinct from §7's HTTP /health poll:
#     §6b confirms launchd registration (supervisor level); §7 confirms the
#     daemon's HTTP listener is up (application level).
#
#     Retry policy (AC2):
#       Attempt 1: run immediately after bootstrap.
#       Attempt 2 (single retry): wait LAUNCHD_LIVENESS_RETRY_DELAY seconds.
#       After both fail: log WARNING but exit 0 — a non-zero exit rolls back
#       the entire .pkg install, which is worse than a slow start.
#       RunAtLoad=true guarantees the daemon starts at next login.
#
#     This check is idempotent: re-running postinstall is safe because the
#     print is read-only and the retry delay is short (≤2s total).
# ---------------------------------------------------------------------------
LAUNCHD_LIVENESS_RETRY_DELAY=2

_check_launchd_pid() {
  launchctl print "gui/${REAL_UID}/${PLIST_LABEL}" 2>/dev/null | grep -q 'pid'
}

echo "[postinstall] verifying launchd registration (ADR-083 §6b)..."
if _check_launchd_pid; then
  echo "[postinstall] launchd service live: ${PLIST_LABEL} registered with a running PID"
else
  echo "[postinstall] launchd PID not yet visible — retrying after ${LAUNCHD_LIVENESS_RETRY_DELAY}s..."
  sleep "${LAUNCHD_LIVENESS_RETRY_DELAY}"
  if _check_launchd_pid; then
    echo "[postinstall] launchd service live (retry): ${PLIST_LABEL} registered with a running PID"
  else
    echo "[postinstall] WARNING: launchd did not report a PID for ${PLIST_LABEL} after bootstrap + retry." >&2
    echo "[postinstall] WARNING: The binary and LaunchAgent are installed. The daemon will start at next login (RunAtLoad=true)." >&2
    # Non-fatal — do NOT exit 1 here (would roll back the entire .pkg install).
  fi
fi

# ---------------------------------------------------------------------------
# 7. Post-install process liveness check — poll /health until daemon is up.
#
#    Success criterion (fix for vault-mtg-tickets#334):
#      binary-present + LaunchAgent-loaded (daemon process started and responding)
#
#    "Not yet paired" (no account_id) is expected on every first-run install
#    because PKCE browser auth is async and user-driven — it cannot complete
#    inside a postinstall window.  Requiring account_id here caused the .pkg to
#    report "Installation failed" (PackageKit Code=112) even when all install
#    artifacts were written correctly.
#
#    New gate: HTTP 200 from /health means the process is up and listening.
#    Any JSON body that parses is accepted regardless of account_id/auth_status.
#    If the daemon never responds within the window, log a WARNING (non-fatal):
#    the binary and LaunchAgent are correctly installed; the daemon will start
#    at next login via RunAtLoad=true.  Pairing state is surfaced in the tray
#    / first-run UX, not as an installer failure.
#
#    curl and python3 are both available on macOS 11+.
# ---------------------------------------------------------------------------
HEALTH_MAX_ATTEMPTS=5
HEALTH_DELAY=3

poll_daemon_liveness() {
  local attempt=1
  while [[ "${attempt}" -le "${HEALTH_MAX_ATTEMPTS}" ]]; do
    echo "[postinstall] liveness check attempt ${attempt}/${HEALTH_MAX_ATTEMPTS}..."
    local http_status body
    # -w writes the HTTP status code to stdout after the body; -o captures body.
    # We need both: HTTP 200 means the process is up, regardless of JSON content.
    body=$(curl -fsS --max-time 2 "${HEALTH_URL}" 2>/dev/null) || true
    if [[ -n "${body}" ]]; then
      # Daemon is responding.  Log pairing state for diagnostics but do NOT
      # gate install success on account_id.
      local account_id auth_status
      account_id=$(python3 -c "
import json, sys
try:
    d = json.loads(sys.stdin.read())
    print(d.get('account_id', ''))
except Exception:
    print('')
" <<< "${body}" 2>/dev/null) || true
      auth_status=$(python3 -c "
import json, sys
try:
    d = json.loads(sys.stdin.read())
    print(d.get('auth_status', 'unknown'))
except Exception:
    print('unknown')
" <<< "${body}" 2>/dev/null) || true
      if [[ -n "${account_id}" ]]; then
        echo "[postinstall] daemon healthy — account_id present (auth_status: ${auth_status})"
      else
        echo "[postinstall] daemon responding — not yet paired (auth_status: ${auth_status}; pairing completes in app)"
      fi
      return 0
    fi
    if [[ "${attempt}" -lt "${HEALTH_MAX_ATTEMPTS}" ]]; then
      sleep "${HEALTH_DELAY}"
    fi
    attempt=$(( attempt + 1 ))
  done
  return 1
}

if poll_daemon_liveness; then
  echo "[postinstall] post-install liveness check passed"
else
  echo "[postinstall] WARNING: daemon did not respond within $(( HEALTH_MAX_ATTEMPTS * HEALTH_DELAY ))s." >&2
  echo "[postinstall] The binary and LaunchAgent are installed correctly." >&2
  echo "[postinstall] The daemon will start automatically at next login (RunAtLoad=true)." >&2
  echo "[postinstall] Check logs at: ${LOG_FILE}" >&2
  # Non-fatal — binary and LaunchAgent are present; do NOT exit 1 here.
fi

# ---------------------------------------------------------------------------
# 8. Log collection-agent-helper version (ADR-059 / hollowmark-tickets#892).
#
# The helper binary is staged at SHARE_DIR by the .pkg payload.  Under ADR-059
# the helper is NO LONGER a LaunchDaemon — it runs as the logged-in user when
# the daemon requests a collection scan, authorized once via
# com.apple.TaskForPid-allow.  No install-helper.sh call is made here; there
# is nothing to register with launchd.
#
# Log the helper version so operators can correlate it with scan telemetry
# (ADR-041 / hollowmark-tickets#1286 R6).
# ---------------------------------------------------------------------------
HELPER_BINARY_PATH="${SHARE_DIR}/collection-helper"

if [[ -f "${HELPER_BINARY_PATH}" ]]; then
  HELPER_VERSION=$("${HELPER_BINARY_PATH}" --version 2>/dev/null || echo "unknown")
  echo "[postinstall] helper_version=${HELPER_VERSION} (no LaunchDaemon — user-space ADR-059 model)"
else
  echo "[postinstall] collection-agent-helper not staged at ${HELPER_BINARY_PATH} — skipping version log."
fi

echo "[postinstall] done"
echo "  Binary : ${BINARY_PATH}"
echo "  plist  : ${PLIST_PATH}"
echo "  Logs   : ${LOG_FILE}"
echo "To uninstall: sudo ${SHARE_DIR}/uninstall.sh"
